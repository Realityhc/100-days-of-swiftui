# ============================================================
# .gitignore для 100 Days of SwiftUI
# ============================================================
# Цей файл каже Git які файли та папки ІГНОРУВАТИ,
# тобто НЕ додавати в репозиторій.
#
# Навіщо це потрібно?
# Xcode створює багато тимчасових та службових файлів,
# які потрібні тільки на твоєму компʼютері.
# Вони важкі, постійно змінюються, і не мають цінності
# для інших людей (або для тебе на іншому компʼютері).
#
# Без .gitignore ці файли потрапляли б в Git і:
# - Роздували б розмір репозиторію (десятки ГБ замість МБ)
# - Створювали б конфлікти при кожному коміті
# - Засмічували б історію змін
# ============================================================

# ----------------------------------------------------------
# Xcode — тимчасові файли збірки
# ----------------------------------------------------------
# DerivedData — це папка куди Xcode складає скомпільований код.
# Вона може займати гігабайти і перестворюється автоматично.
build/
DerivedData/

# Файли стану користувача Xcode (позиція курсора, відкриті вкладки тощо)
# Це персональні налаштування, які не потрібні в репозиторії
*.xcuserstate
*.xcuserdatad/

# Xcode workspace — персональні налаштування робочого простору
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/

# ----------------------------------------------------------
# Xcode — файли схем збірки (якщо вони shared — не ігноруємо)
# ----------------------------------------------------------
# Зазвичай схеми зберігаються в xcuserdata і вже ігноруються вище.
# Але якщо ти позначиш схему як "Shared" в Xcode, вона збережеться
# в xcshareddata — і це ДОБРЕ, її варто комітити.

# ----------------------------------------------------------
# Swift Package Manager
# ----------------------------------------------------------
# Залежності, які завантажуються автоматично
.build/
Packages/
*.resolved

# ----------------------------------------------------------
# CocoaPods (якщо будеш використовувати)
# ----------------------------------------------------------
# Pods/ — завантажені бібліотеки. Деякі розробники комітять їх,
# але для навчання краще ігнорувати — вони завантажаться автоматично.
Pods/

# ----------------------------------------------------------
# macOS системні файли
# ----------------------------------------------------------
# .DS_Store — прихований файл macOS, який зберігає налаштування
# відображення папки (розмір іконок, сортування тощо).
# Абсолютно не потрібний в Git.
.DS_Store
.DS_Store?
._*

# Spotlight (пошук macOS)
.Spotlight-V100

# Кошик macOS
.Trashes

# ----------------------------------------------------------
# Різне
# ----------------------------------------------------------
# Тимчасові файли
*.swp
*.swo
*~

# Архіви Xcode
*.ipa
*.dSYM.zip
*.dSYM

# Playgrounds — тимчасові дані
timeline.xctimeline
playground.xcworkspace

# ----------------------------------------------------------
# Що НЕ ігнорується (і потрапляє в Git):
# ----------------------------------------------------------
# ✅ Весь твій Swift код (.swift файли)
# ✅ Файли проєкту (.xcodeproj — але без xcuserdata)
# ✅ Storyboards та XIB файли
# ✅ Assets (зображення, кольори, іконки)
# ✅ Info.plist
# ✅ README.md та інші документи
# ✅ Shared схеми збірки
# ----------------------------------------------------------
